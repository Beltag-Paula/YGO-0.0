<style>
 /* ==========================================
   RETRO DUEL ARENA GLOBAL STYLES
   ========================================== */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  user-select: none;
}

body {
  background-color: #0b0f19;
  background-image: 
    radial-gradient(circle at 50% 50%, rgba(20, 35, 65, 0.6), rgba(5, 8, 15, 0.95)),
    url('https://images.unsplash.com/photo-1599740449203-417c664d5bc5?q=80&w=1920'); /* Dark stone/marble texture */
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  font-family: 'Arial Black', 'Impact', sans-serif;
  color: #e0e6ed;
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow-x: hidden;
}

.game-board {
  display: flex;
  flex-direction: column;
  gap: 20px;
  width: 100%;
  max-width: 1200px;
  padding: 20px;
  background: rgba(0, 0, 0, 0.4);
  border: 4px double #2a4d7c;
  box-shadow: 0 0 30px rgba(0, 0, 0, 0.8), inset 0 0 50px rgba(16, 37, 66, 0.5);
  border-radius: 12px;
}

/* ==========================================
   PLAYER & OPPONENT SECTIONS
   ========================================== */
.player-section {
  display: flex;
  flex-direction: column;
  gap: 15px;
  position: relative;
  width: 100%;
}

/* Reverse layout for the opponent side so the hands/mats mirror correctly */
/* Fixes opponent structural stack so hand sits perfectly above S/T zone */
.opponent-side {
  display: flex;
  flex-direction: column; 
  gap: 15px;
}
/* ==========================================
   THE PLAYMAT (Classic Grid Layout)
   ========================================== */
.playmat {
  display: grid;
  grid-template-columns: 140px 1fr 140px;
  gap: 15px;
  background: rgba(8, 15, 28, 0.7);
  border: 2px solid #1a3354;
  border-radius: 8px;
  padding: 15px;
  box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.9);
  position: relative;
}

/* Power of Chaos style center division line */
.playmat::after {
  content: '';
  position: absolute;
  left: 10%;
  right: 10%;
  height: 2px;
  background: linear-gradient(90deg, transparent, #225588, #4488dd, #225588, transparent);
  opacity: 0.6;
}
.player-side .playmat::after { top: 0; }
.opponent-side .playmat::after { bottom: 0; }

.mat-side {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 15px;
}

.mat-center {
  display: flex;
  flex-direction: column;
  gap: 15px;
  justify-content: center;
}

.field-row {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10px;
}

/* ==========================================
   SLOTS & CARDS (The Retro Cyber Blueprint Look)
   ========================================== */
.slot {
  aspect-ratio: 1 / 1.45; /* Yu-Gi-Oh card ratio */
  background: rgba(13, 27, 49, 0.6);
  border: 2px solid #1f426e;
  border-radius: 6px;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: inset 0 0 12px rgba(0, 200, 255, 0.15);
  transition: all 0.2s ease;
}

/* Cybernetic Hologram Labels */
.slot::before {
  content: attr(data-label);
  position: absolute;
  font-size: 10px;
  letter-spacing: 1px;
  color: #3b74b3;
  text-shadow: 0 0 4px rgba(59, 116, 179, 0.6);
  font-weight: bold;
  z-index: 1;
  pointer-events: none;
  text-align: center;
}

.card {
  width: 92%;
  height: 92%;
  border-radius: 4px;
  position: relative;
  z-index: 2;
  box-shadow: 3px 5px 10px rgba(0,0,0,0.7);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  cursor: pointer;
}

.card img {
  width: 100%;
  height: 100%;
  object-fit: fill;
  border-radius: 4px;
  display: block;
}

/* Classic Card Back (Iconic orange/brown swirl vibe) */
.card.face-down {
  background: #3d1d11;
  border: 2px solid #1c0c06;
  background-image: 
    radial-gradient(circle, #78381e 20%, transparent 60%),
    linear-gradient(45deg, #1c0c06 25%, transparent 25%), 
    linear-gradient(-45deg, #1c0c06 25%, transparent 25%);
  background-size: 20px 20px, 10px 10px, 10px 10px;
  box-shadow: 0 4px 6px rgba(0,0,0,0.6);
}
.card.face-down img {
  display: none; /* Hide real art if facedown */
}

/* Card Gameplay Positions */
.card.DEF, .card.def, .card.defense {
  transform: rotate(90deg) scale(0.9);
  box-shadow: 5px 3px 10px rgba(0,0,0,0.7);
}

/* Hover effects to feel interactive */
.card:hover {
  transform: translateY(-4px) scale(1.03);
  box-shadow: 0 8px 16px rgba(0, 200, 255, 0.3);
  z-index: 10;
}
.card.DEF:hover {
  transform: rotate(90deg) translateY(-4px) scale(1.03);
}

/* ==========================================
   THE HANDS
   ========================================== */
.hand {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: -15px; /* Slight classic fan overlap */
  padding: 10px 0;
  min-height: 110px;
}

.hand .card {
  width: 75px;
  height: 110px;
  margin: 0 -8px; /* Force cards to layer over one another slightly */
}

.hand .card:hover {
  transform: translateY(-20px) scale(1.2);
}

/* ==========================================
   UI / LIFE POINT DISPLAYS (Tag Force Style)
   ========================================== */
.player-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(90deg, #0f2340, rgba(15, 35, 64, 0.2));
  border-left: 5px solid #00d2ff;
  padding: 8px 15px;
  border-radius: 4px;
}

.opponent-side .player-info {
  background: linear-gradient(90deg, #401414, rgba(64, 20, 20, 0.2));
  border-left: 5px solid #ff3b3b;
}

.player-info h2 {
  font-size: 16px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #ffffff;
}

/* Nostalgic Arcade Digital LP text */
.lp-display {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22px;
  font-weight: bold;
  color: #00ffcc;
  text-shadow: 0 0 8px rgba(0, 255, 204, 0.8);
  background: rgba(0, 0, 0, 0.4);
  padding: 2px 12px;
  border-radius: 4px;
  border: 1px solid rgba(0, 255, 204, 0.3);
}

.opponent-side .lp-display {
  color: #ff3344;
  text-shadow: 0 0 8px rgba(255, 51, 68, 0.8);
  border: 1px solid rgba(255, 51, 68, 0.3);
}

/* ==========================================
   INTERACTIVE PHASE BAR (OLD SCHOOL UI)
   ========================================== */
.phase-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: linear-gradient(180deg, #162436 0%, #0c1524 100%);
  border: 2px solid #294366;
  border-radius: 6px;
  padding: 6px 12px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.5), inset 0 1px 3px rgba(255,255,255,0.1);
  margin: 5px 0;
  z-index: 10;
}

.phase-btn {
  background: transparent;
  border: none;
  color: #5d7fa3;
  font-family: 'Arial Black', 'Impact', sans-serif;
  font-size: 11px;
  letter-spacing: 2px;
  padding: 6px 16px;
  cursor: pointer;
  text-transform: uppercase;
  transition: all 0.2s ease;
  border-radius: 4px;
  text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
}

/* Hover style */
.phase-btn:hover {
  color: #a3c2e6;
  background: rgba(255, 255, 255, 0.05);
}

/* Active phase state - Classic Golden/Amber Hologram text */
.phase-btn.active {
  color: #ffaa00;
  background: linear-gradient(180deg, rgba(255,170,0,0.15) 0%, rgba(255,110,0,0.02) 100%);
  border-left: 2px solid #ffaa00;
  border-right: 2px solid #ffaa00;
  text-shadow: 0 0 8px rgba(255, 170, 0, 0.7);
  box-shadow: inset 0 0 8px rgba(255, 170, 0, 0.1);
}
</style>