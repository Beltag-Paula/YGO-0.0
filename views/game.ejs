<!DOCTYPE html>
<html>
<head>
  <title>Yu-Gi-Oh Duel Arena</title>
  <style>
    body {
      background-color: #1a1a1a;
      color: #fff;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      margin: 0;
      padding: 10px;
    }
    .game-board {
      display: flex;
      flex-direction: column;
      max-width: 1200px;
      margin: 0 auto;
      gap: 15px;
    }
    .player-section {
      background: #262626;
      border: 3px solid #3d3d3d;
      border-radius: 12px;
      padding: 15px;
      position: relative;
    }
    .player-section.active-turn {
      border-color: #ffcc00;
      box-shadow: 0 0 15px rgba(255, 204, 0, 0.4);
    }
    .player-info {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }
    .lp-display {
      font-size: 24px;
      font-weight: bold;
      color: #00ffcc;
      text-shadow: 0 0 5px rgba(0,255,204,0.3);
    }
    .hand {
      display: flex;
      justify-content: center;
      gap: 10px;
      min-height: 120px;
      padding: 10px;
      background: rgba(0,0,0,0.2);
      border-radius: 8px;
    }
    .playmat {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin: 15px 0;
    }
    .mat-side {
      display: flex;
      flex-direction: column;
      gap: 10px;
      width: 12%;
    }
    .mat-center {
      display: flex;
      flex-direction: column;
      gap: 10px;
      width: 74%;
    }
    .field-row {
      display: flex;
      justify-content: space-around;
      gap: 5px;
      background: rgba(255,255,255,0.03);
      padding: 8px;
      border-radius: 6px;
    }
    .slot {
      border: 2px dashed #4a4a4a;
      border-radius: 6px;
      width: 80px;
      height: 115px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .slot::after {
      content: attr(data-label);
      font-size: 10px;
      color: #666;
      position: absolute;
      bottom: 2px;
    }
    .card {
      width: 74px;
      height: 108px;
      border-radius: 4px;
      overflow: hidden;
      box-shadow: 0 4px 6px rgba(0,0,0,0.3);
      background-size: cover;
      position: relative;
      transition: transform 0.2s, box-shadow 0.2s, outline 0.2s;
      cursor: pointer;
      user-select: none;
    }
    .card.defense {
      transform: rotate(90deg);
    }
    .card img {
      width: 100%;
      height: 100%;
      object-fit: fill;
      pointer-events: none;
    }
    .card.face-down {
      background: linear-gradient(135deg, #8b0000 0%, #4a0000 100%);
      border: 2px solid #ffcc00;
    }
    .card.face-down img {
      display: none;
    }
    
    /* Dynamic UI State Customizations */
    .card.selected {
      outline: 3px solid #ffcc00;
      box-shadow: 0 0 15px #ffcc00;
    }
    .summon-btn {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      width: 100%; height: 100%;
      background: rgba(0, 0, 0, 0.8);
      color: #ffcc00;
      font-weight: bold;
      font-size: 10px;
      text-shadow: 1px 1px 2px black;
      text-align: center;
      display: none;
      align-items: center;
      justify-content: center;
      pointer-events: none;
    }
    .card.selected .summon-btn {
      display: flex;
    }
    .card.selected[data-summonable="false"] .summon-btn {
      color: #ffaa00;
    }

    .phase-bar {
      display: flex;
      justify-content: center;
      background: #333;
      padding: 10px;
      border-radius: 8px;
      gap: 10px;
    }
    .phase-btn {
      background: #444;
      border: 1px solid #555;
      color: #aaa;
      padding: 8px 16px;
      font-weight: bold;
      border-radius: 4px;
      cursor: pointer;
    }
    .phase-btn.active {
      background: #ffcc00;
      color: #111;
      border-color: #fff;
      box-shadow: 0 0 10px rgba(255,204,0,0.5);
    }
    .deck-counter {
      position: absolute;
      background: rgba(0,0,0,0.8);
      color: #fff;
      padding: 2px 6px;
      font-size: 11px;
      font-weight: bold;
      border-radius: 4px;
      top: 5px; right: 5px;
    }
  </style>
</head>
<body>

  <div class="game-board">

    <!-- OPPONENT SIDE (PLAYER 2) -->
    <div class="player-section opponent-side <%= currentPlayer.name === player2.name ? 'active-turn' : '' %>">
      <div class="player-info">
        <h2><%= player2.name %> <span style="font-size: 14px; color: #aaa;"><%= currentPlayer.name === player2.name ? '(Acting)' : '' %></span></h2>
        <div class="lp-display">LP: <%= player2.lifePoints %></div>
      </div>

      <div class="hand">
        <% player2.zone.hand.forEach(gameCard => { %>
          <div class="card face-down"></div>
        <% }) %>
      </div>

      <div class="playmat">
        <div class="mat-side">
          <div class="slot" data-label="Field">
            <% if(player2.zone.field) { %>
              <div class="card <%= player2.zone.field.faceUp ? '' : 'face-down' %>">
                <img src="<%= player2.zone.field.card.image %>" />
              </div>
            <% } %>
          </div>
          <div class="slot" data-label="Extra (<%= player2.zone.extraDeck.length %>)"></div>
        </div>

        <div class="mat-center">
          <div class="field-row">
            <% player2.zone.spellTrap.forEach((gameCard, index) => { %>
              <div class="slot" data-label="S/T <%= index+1 %>">
                <% if(gameCard) { %>
                  <div class="card <%= gameCard.faceUp ? '' : 'face-down' %>">
                    <img src="<%= gameCard.card.image %>" />
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>

          <div class="field-row">
            <% player2.zone.monster.forEach((gameCard, index) => { %>
              <div class="slot" data-label="M <%= index+1 %>">
                <% if(gameCard) { %>
                  <div class="card <%= gameCard.faceUp ? '' : 'face-down' %> <%= gameCard.position %>">
                    <img src="<%= gameCard.card.image %>" />
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="mat-side">
          <div class="slot" data-label="Banish (<%= player2.zone.banished ? player2.zone.banished.length : 0 %>)">
            <% if(player2.zone.banished && player2.zone.banished.length > 0) { %>
              <div class="card"><img src="<%= player2.zone.banished[player2.zone.banished.length - 1].card.image %>" /></div>
            <% } %>
          </div>
          <div class="slot" data-label="GY (<%= player2.zone.graveyard.length %>)">
            <% if(player2.zone.graveyard.length > 0) { %>
              <div class="card"><img src="<%= player2.zone.graveyard[player2.zone.graveyard.length - 1].card.image %>" /></div>
            <% } %>
          </div>
          <div class="slot" data-label="Deck">
            <% if(player2.zone.deck.length > 0) { %> 
              <div class="card face-down"></div> 
              <span class="deck-counter"><%= player2.zone.deck.length %></span>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- PHASE BAR SYSTEM -->
    <form action="/game/next-phase" method="POST" class="phase-bar">
      <button type="button" class="phase-btn <%= phase === 'draw' ? 'active' : '' %>">DRAW</button>
      <button type="button" class="phase-btn <%= phase === 'standby' ? 'active' : '' %>">STANDBY</button>
      <button type="button" class="phase-btn <%= phase === 'm1' || phase === 'idle' ? 'active' : '' %>">MAIN 1</button>
      <button type="button" class="phase-btn <%= phase === 'battle' ? 'active' : '' %>">BATTLE</button>
      <button type="button" class="phase-btn <%= phase === 'm2' ? 'active' : '' %>">MAIN 2</button>
      <button type="button" class="phase-btn <%= phase === 'end' ? 'active' : '' %>">END</button>
      
      <% if (currentPlayer.name === player1.name) { %>
        <button type="submit" class="phase-btn" style="background-color: #00ffcc; color: #111; margin-left: 20px;">
          <%= (typeof waitingForAction !== 'undefined' && waitingForAction) ? "PASS ACTION" : "NEXT PHASE" %> ➔
        </button>
      <% } else { %>
        <button type="submit" class="phase-btn" style="background-color: #ff3333; color: #fff; margin-left: 20px;">
          FORCE AI TURN STEP ➔
        </button>
      <% } %>
    </form>

    <!-- ACTIVE PLAYER SIDE (PLAYER 1) -->
    <div class="player-section player-side <%= currentPlayer.name === player1.name ? 'active-turn' : '' %>">
      <div class="player-info">
        <h2><%= player1.name %> <span style="font-size: 14px; color: #aaa;"><%= currentPlayer.name === player1.name ? '(Your Turn)' : '' %></span></h2>
        <div class="lp-display">LP: <%= player1.lifePoints %></div>
      </div>

      <div class="playmat">
        <div class="mat-side">
          <div class="slot" data-label="Field">
            <% if(player1.zone.field) { %>
              <div class="card <%= player1.zone.field.faceUp ? '' : 'face-down' %>">
                <img src="<%= player1.zone.field.card.image %>" />
              </div>
            <% } %>
          </div>
          <div class="slot" data-label="Extra (<%= player1.zone.extraDeck.length %>)"></div>
        </div>

        <div class="mat-center">
          <div class="field-row">
            <% player1.zone.monster.forEach((gameCard, index) => { %>
              <div class="slot" data-label="M <%= index+1 %>">
                <% if(gameCard) { %>
                  <div class="card <%= gameCard.faceUp ? '' : 'face-down' %> <%= gameCard.position %>">
                    <img src="<%= gameCard.card.image %>" />
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>

          <div class="field-row">
            <% player1.zone.spellTrap.forEach((gameCard, index) => { %>
              <div class="slot" data-label="S/T <%= index+1 %>">
                <% if(gameCard) { %>
                  <div class="card <%= gameCard.faceUp ? '' : 'face-down' %>">
                    <img src="<%= gameCard.card.image %>" />
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="mat-side">
          <div class="slot" data-label="Banish (<%= player1.zone.banished ? player1.zone.banished.length : 0 %>)">
            <% if(player1.zone.banished && player1.zone.banished.length > 0) { %>
              <div class="card"><img src="<%= player1.zone.banished[player1.zone.banished.length - 1].card.image %>" /></div>
            <% } %>
          </div>
          <div class="slot" data-label="GY (<%= player1.zone.graveyard.length %>)">
            <% if(player1.zone.graveyard.length > 0) { %>
              <div class="card"><img src="<%= player1.zone.graveyard[player1.zone.graveyard.length - 1].card.image %>" /></div>
            <% } %>
          </div>
          <div class="slot" data-label="Deck">
            <% if(player1.zone.deck.length > 0) { %> 
              <div class="card face-down"></div> 
              <span class="deck-counter"><%= player1.zone.deck.length %></span>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Player Hand Zone -->
      <div class="hand">
        <% player1.zone.hand.forEach(gameCard => { %>
          <% 
            const isMonsterCard = gameCard.card.type.includes("Monster") || gameCard.card.frameType === "normal" || gameCard.card.frameType === "effect";
            const isTurnAndPhaseValid = (currentPlayer.name === player1.name) && 
                                        (typeof waitingForAction !== 'undefined' && waitingForAction) && 
                                        (typeof actedThisWindow !== 'undefined' && !actedThisWindow);
            const canNormalSummon = isMonsterCard && isTurnAndPhaseValid;
          %>
          <div class="card player-hand-card" 
               data-instance-id="<%= gameCard.instanceId %>"
               data-summonable="<%= canNormalSummon ? 'true' : 'false' %>">
            
            <img src="<%= gameCard.card.image %>" />
            
            <div class="summon-btn">
              <% if (isMonsterCard) { %>
                NORMAL SUMMON
              <% } else { %>
                CANNOT SUMMON
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

  </div>

  <!-- BIND SELECTION ENGINE -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const handCards = document.querySelectorAll(".player-hand-card");

      handCards.forEach(card => {
        card.addEventListener("click", (e) => {
          e.preventDefault();
          e.stopPropagation();

          const instanceId = card.getAttribute("data-instance-id");
          const isAlreadySelected = card.classList.contains("selected");

          if (isAlreadySelected) {
            // SECOND CLICK: Submit action immediately if instance ID exists
            if (instanceId) {
              const form = document.createElement("form");
              form.method = "POST";
              form.action = "/game/summon";

              const input = document.createElement("input");
              input.type = "hidden";
              input.name = "instanceId";
              input.value = instanceId;

              form.appendChild(input);
              document.body.appendChild(form);
              form.submit();
            }
          } else {
            // FIRST CLICK: Highlight card and reveal context action overlay
            handCards.forEach(c => c.classList.remove("selected"));
            card.classList.add("selected");
          }
        });
      });

      // Reset selection if clicking anywhere outside of hand layout
      document.addEventListener("click", (e) => {
        if (!e.target.closest(".player-hand-card")) {
          handCards.forEach(c => c.classList.remove("selected"));
        }
      }, true);
    });
  </script>

</body>
</html>